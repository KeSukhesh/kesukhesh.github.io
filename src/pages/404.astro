---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <section class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-forest mb-4">404</h1>
      <p class="text-lg text-muted mb-8">This page doesn't exist.</p>
      <a href="/" class="text-forest hover:text-forest-light underline transition-colors">
        Go home
      </a>
    </div>
  </section>
</BaseLayout>
