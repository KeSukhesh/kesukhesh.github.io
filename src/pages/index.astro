---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ScrollProgress from '../components/ScrollProgress.astro';

const name = "Sukhesh Patro";
const nameLetters = name.split('');

const projects = [
  {
    title: 'Sheaf',
    description: 'Agent orchestration platform built from scratch. ReAct reasoning loop, coordinator mode with parallel workers, tiered permissions, and hybrid vector/keyword RAG search via pgvector.',
    tags: ['TypeScript', 'Anthropic SDK', 'MCP', 'pgvector'],
    url: 'https://github.com/kesukhesh/sheaf',
  },
  {
    title: 'FishSOOP',
    description: 'Full-stack ocean data platform. Ingests 12M+ observations from 50,000+ fishing vessel deployments via THREDDS catalog crawling and NetCDF parsing over OPeNDAP.',
    tags: ['FastAPI', 'PostGIS', 'Next.js', 'Docker'],
    url: 'https://github.com/kesukhesh/fishsoop',
  },
];

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const blogPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Sukhesh Patro" description="Personal website of Sukhesh Patro." fullHeight>
  <ScrollProgress />

  <!-- Hero Section -->
  <section id="hero" class="snap-section min-h-screen flex flex-col items-center justify-center px-6 relative grid-bg">
    <!-- Misty hills card -->
    <div class="relative z-10 w-full max-w-4xl mx-auto mb-12" style="margin-top: calc(4vh + 4px);" class="!-mt-2 md:!mt-[calc(4vh+4px)]">
      <div class="relative overflow-hidden border border-[#B4BCA0] shadow-[0_4px_30px_rgba(74,82,64,0.12)]" style="height: 40vh; background: #D5D1C8;">
        <svg viewBox="0 0 1440 630" class="w-full h-full" preserveAspectRatio="none">
          <!-- Sky/mist background -->
          <rect width="1440" height="630" fill="#D5D1C8"/>
          <!-- Furthest hill - lightest, gentle wide arc -->
          <path d="M0,360 C180,280 320,320 520,260 C720,200 880,250 1060,220 C1200,200 1340,240 1440,270 L1440,630 L0,630 Z" fill="#C8CCB8" opacity="0.6"/>
          <!-- Second hill - slightly asymmetric, peaks left -->
          <path d="M0,320 C120,360 280,280 460,320 C640,360 760,290 940,330 C1100,360 1260,310 1440,350 L1440,630 L0,630 Z" fill="#B4BCA0" opacity="0.7"/>
          <!-- Middle hill - broad sweeping curve, peaks right -->
          <path d="M0,420 C200,380 380,410 560,360 C740,310 900,370 1080,330 C1220,300 1360,350 1440,380 L1440,630 L0,630 Z" fill="#A3A88B" opacity="0.75"/>
          <!-- Front-middle hill - sharper undulations -->
          <path d="M0,480 C100,440 240,470 400,430 C520,400 660,450 820,420 C960,395 1100,440 1260,410 C1360,390 1420,420 1440,440 L1440,630 L0,630 Z" fill="#7E876A" opacity="0.85"/>
          <!-- Second-front hill - rolling, offset rhythm -->
          <path d="M0,530 C180,500 300,540 480,510 C680,475 820,520 1000,490 C1140,465 1300,510 1440,500 L1440,630 L0,630 Z" fill="#5B6349" opacity="0.9"/>
          <!-- Closest hill - gentle foreground -->
          <path d="M0,570 C240,545 420,565 660,540 C860,515 1040,555 1240,535 C1360,525 1420,545 1440,555 L1440,630 L0,630 Z" fill="#4A5240"/>
        </svg>
        <!-- Fog layer 1 - slow drift, lower and darker -->
        <div class="absolute inset-0 fog-drift-1 pointer-events-none">
          <svg viewBox="0 0 2880 630" class="h-full" style="width: 200%;" preserveAspectRatio="none">
            <!-- First pass -->
            <ellipse cx="400" cy="380" rx="500" ry="70" fill="#A3A88B" opacity="0.45"/>
            <ellipse cx="1100" cy="420" rx="400" ry="55" fill="#B4BCA0" opacity="0.4"/>
            <!-- Duplicate offset by 1440 for seamless loop -->
            <ellipse cx="1840" cy="380" rx="500" ry="70" fill="#A3A88B" opacity="0.45"/>
            <ellipse cx="2540" cy="420" rx="400" ry="55" fill="#B4BCA0" opacity="0.4"/>
          </svg>
        </div>
        <!-- Fog layer 2 - faster, thinner wisps, lower -->
        <div class="absolute inset-0 fog-drift-2 pointer-events-none">
          <svg viewBox="0 0 2880 630" class="h-full" style="width: 200%;" preserveAspectRatio="none">
            <!-- First pass -->
            <ellipse cx="300" cy="440" rx="350" ry="35" fill="#A3A88B" opacity="0.3"/>
            <ellipse cx="900" cy="350" rx="300" ry="30" fill="#B4BCA0" opacity="0.25"/>
            <!-- Duplicate offset by 1440 for seamless loop -->
            <ellipse cx="1740" cy="440" rx="350" ry="35" fill="#A3A88B" opacity="0.3"/>
            <ellipse cx="2340" cy="350" rx="300" ry="30" fill="#B4BCA0" opacity="0.25"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Title + tagline below hills -->
    <div class="text-center relative z-10">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-4 leading-tight" aria-label={name}>
        {nameLetters.map((letter, i) => (
          <span
            class:list={['letter-drop', { 'w-3 md:w-4': letter === ' ' }]}
            style={`animation-delay: ${i * 0.06}s;`}
            aria-hidden="true"
          >
            {letter === ' ' ? '\u00A0' : letter}
          </span>
        ))}
      </h1>
      <p
        class="fade-in-delayed text-lg md:text-xl text-ink/70 max-w-lg mx-auto italic"
        style={`animation-delay: ${nameLetters.length * 0.06 + 0.3}s;`}
      >
        I like to think.
      </p>

      <!-- Social links -->
      <div
        class="fade-in-delayed flex items-center justify-center gap-6 mt-6"
        style={`animation-delay: ${nameLetters.length * 0.06 + 0.6}s;`}
      >
        <a href="https://github.com/kesukhesh" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-ink/60 hover:text-ink transition-colors duration-200">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/sukheshkp" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-ink/60 hover:text-ink transition-colors duration-200">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://www.instagram.com/sukhesh_kp/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-ink/60 hover:text-ink transition-colors duration-200">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 bounce-down z-10">
      <svg class="w-6 h-6 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-8">About</h2>

      <div class="reveal reveal-delay-1 space-y-6 text-lg leading-relaxed text-forest-dark/80 dark:text-muted">
        <p>
          I started as an engineer. Now I build businesses the same way I build software: as systems. I lead Engineering, People, and Sales at <a href="https://www.lyratechnologies.com.au/" target="_blank" rel="noopener noreferrer" class="text-ink font-medium hover:text-forest transition-colors border-b border-ink/20 hover:border-forest">Lyra</a>, where we've scaled from 25 to 85+ engineers.
        </p>
        <p>
          Philosophy and economics shape how I think about most things. Personal growth fills in the rest. I read a lot, write when something sticks, and try to get better at all of it every day.
        </p>
      </div>

      <div class="reveal reveal-delay-2 flex flex-wrap gap-3 mt-10">
        {['Lyra', 'UNSW', 'Engineering', 'Philosophy', 'Economics', 'Personal Growth', 'Systems'].map((tag) => (
          <span class="px-4 py-2 text-sm font-mono bg-forest/10 text-forest rounded-full border border-forest/20">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-12">Projects</h2>

      <div class="grid md:grid-cols-2 gap-6">
        {projects.map((project, i) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'reveal',
              `reveal-delay-${i + 1}`,
              'group block p-6 rounded-xl border border-border',
              'hover:border-forest/50 hover:-translate-y-1',
              'transition-all duration-300',
            ]}
          >
            <h3 class="text-xl font-bold mb-3 group-hover:text-forest transition-colors">
              {project.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed mb-4 italic">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="text-xs font-mono px-2 py-1 bg-paper border border-border rounded">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Teaser Section -->
  <section id="blog" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-12">Writing</h2>

      <div class="space-y-6">
        {blogPosts.map((post, i) => (
          <a href={`/blog/${post.id}`} class:list={['reveal', `reveal-delay-${i + 1}`, 'group block border-b border-border pb-6 last:border-0']}>
            <p class="text-sm font-mono text-muted mb-2">
              {post.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h3 class="text-xl font-bold mb-2 group-hover:text-forest transition-colors">
              {post.data.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed italic">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>

      <div class="reveal reveal-delay-4 mt-10">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-forest hover:text-forest-light font-medium transition-colors"
        >
          View all posts
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>



  <ScrollReveal />
</BaseLayout>

<script>
  function updateSnapPage() {
    const isHome = window.location.pathname === '/' || window.location.pathname === '';
    document.documentElement.classList.toggle('snap-page', isHome);
  }

  updateSnapPage();
  document.addEventListener('astro:after-swap', updateSnapPage);
</script>
