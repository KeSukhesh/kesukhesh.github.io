---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ScrollProgress from '../components/ScrollProgress.astro';

const name = "Sukhesh Patro";
const nameLetters = name.split('');

const projects = [
  {
    title: 'Sheaf',
    description: 'A collaborative knowledge management tool that helps teams organise and connect ideas across documents.',
    tags: ['TypeScript', 'React', 'Node.js'],
    url: 'https://github.com/kesukhesh/sheaf',
  },
  {
    title: 'FishSOOP',
    description: 'Computer vision pipeline for automated fish species identification and population monitoring.',
    tags: ['Python', 'ML', 'Computer Vision'],
    url: 'https://github.com/kesukhesh/fishsoop',
  },
];

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const blogPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Sukhesh Patro" description="Software engineer, builder, thinker. Personal website of Sukhesh Patro." fullHeight>
  <ScrollProgress />

  <!-- Hero Section -->
  <section id="hero" class="snap-section min-h-screen flex flex-col items-center justify-center px-6 relative">
    <div class="text-center">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight" aria-label={name}>
        {nameLetters.map((letter, i) => (
          <span
            class:list={['letter-drop', { 'w-3 md:w-4': letter === ' ' }]}
            style={`animation-delay: ${i * 0.06}s;`}
            aria-hidden="true"
          >
            {letter === ' ' ? '\u00A0' : letter}
          </span>
        ))}
      </h1>
      <p
        class="fade-in-delayed text-lg md:text-xl text-muted max-w-lg mx-auto"
        style={`animation-delay: ${nameLetters.length * 0.06 + 0.3}s;`}
      >
        Software engineer, builder, thinker.
      </p>

      <!-- Social links -->
      <div
        class="fade-in-delayed flex items-center justify-center gap-6 mt-8"
        style={`animation-delay: ${nameLetters.length * 0.06 + 0.6}s;`}
      >
        <a
          href="https://github.com/kesukhesh"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-muted hover:text-forest transition-colors duration-200"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/sukheshkp"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-muted hover:text-forest transition-colors duration-200"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="mailto:sukhesh@kesukhesh.com"
          aria-label="Email"
          class="text-muted hover:text-forest transition-colors duration-200"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 bounce-down">
      <svg class="w-6 h-6 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-8">About</h2>

      <div class="reveal reveal-delay-1 space-y-6 text-lg leading-relaxed text-muted">
        <p>
          I'm a software engineer at <span class="text-ink font-medium">Lyra Technologies</span>, where I build automation systems and tools that help businesses work smarter. I graduated from the <span class="text-ink font-medium">University of New South Wales</span> with a focus on computer science and a deep curiosity for how things work.
        </p>
        <p>
          I care about writing clean, purposeful code — the kind that's easy to understand, maintain, and extend. When I'm not coding, I'm usually exploring ideas around AI, reading, or working on side projects.
        </p>
      </div>

      <div class="reveal reveal-delay-2 flex flex-wrap gap-3 mt-10">
        {['Lyra Technologies', 'UNSW', 'Automation', 'AI / ML', 'Full-Stack', 'TypeScript', 'Python'].map((tag) => (
          <span class="px-4 py-2 text-sm font-mono bg-forest/10 text-forest rounded-full border border-forest/20">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-12">Projects</h2>

      <div class="grid md:grid-cols-2 gap-6">
        {projects.map((project, i) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'reveal',
              `reveal-delay-${i + 1}`,
              'group block p-6 rounded-xl border border-border',
              'hover:border-forest/50 hover:-translate-y-1',
              'transition-all duration-300',
            ]}
          >
            <h3 class="text-xl font-bold mb-3 group-hover:text-forest transition-colors">
              {project.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed mb-4">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="text-xs font-mono px-2 py-1 bg-paper border border-border rounded">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Teaser Section -->
  <section id="blog" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-12">Writing</h2>

      <div class="space-y-6">
        {blogPosts.map((post, i) => (
          <a href={`/blog/${post.id}`} class:list={['reveal', `reveal-delay-${i + 1}`, 'group block border-b border-border pb-6 last:border-0']}>
            <p class="text-sm font-mono text-muted mb-2">
              {post.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h3 class="text-xl font-bold mb-2 group-hover:text-forest transition-colors">
              {post.data.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>

      <div class="reveal reveal-delay-4 mt-10">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-forest hover:text-forest-light font-medium transition-colors"
        >
          View all posts
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="snap-section min-h-screen flex items-center px-6 py-20">
    <div class="max-w-3xl mx-auto w-full text-center">
      <h2 class="reveal text-3xl md:text-4xl font-bold mb-8">Get in Touch</h2>

      <p class="reveal reveal-delay-1 text-lg text-muted max-w-md mx-auto mb-10 leading-relaxed">
        I'm always open to interesting conversations, collaborations, or just saying hello.
      </p>

      <a
        href="mailto:sukhesh@kesukhesh.com"
        class="reveal reveal-delay-2 inline-flex items-center gap-3 px-8 py-4 bg-forest text-white rounded-xl font-medium hover:bg-forest-light transition-colors duration-200"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        sukhesh@kesukhesh.com
      </a>

      <div class="reveal reveal-delay-3 flex items-center justify-center gap-6 mt-10">
        <a
          href="https://github.com/kesukhesh"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-muted hover:text-forest transition-colors duration-200"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/sukheshkp"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-muted hover:text-forest transition-colors duration-200"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <ScrollReveal />
</BaseLayout>

<script>
  function setupSnapPage() {
    // Only enable snap on the landing page
    if (window.location.pathname === '/' || window.location.pathname === '') {
      document.documentElement.classList.add('snap-page');
    }
  }

  function cleanupSnapPage() {
    document.documentElement.classList.remove('snap-page');
  }

  setupSnapPage();
  document.addEventListener('astro:before-swap', cleanupSnapPage);
  document.addEventListener('astro:after-swap', setupSnapPage);
</script>
