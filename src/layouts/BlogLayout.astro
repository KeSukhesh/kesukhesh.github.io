---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, tags, readingTime, headings } = Astro.props;

const formattedDate = date.toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={`${title} — Sukhesh Patro`} description={description}>
  <article class="px-6 py-16 md:py-24">
    <div class="max-w-3xl mx-auto">
      <!-- Post header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 text-sm font-mono text-muted mb-4">
          <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
          <span aria-hidden="true">&middot;</span>
          <span>{readingTime}</span>
        </div>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-6">
          {title}
        </h1>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/blog/tags/${tag}`}
                class="text-xs font-mono px-3 py-1 bg-forest/10 text-forest rounded-full border border-forest/20 hover:bg-forest/20 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <!-- Table of Contents -->
      {tocHeadings.length > 0 && (
        <nav class="mb-12 p-6 rounded-xl border border-border bg-paper" aria-label="Table of contents">
          <h2 class="text-sm font-mono font-bold text-muted uppercase tracking-wider mb-4">
            On this page
          </h2>
          <ul class="space-y-2">
            {tocHeadings.map((heading) => (
              <li class:list={[heading.depth === 3 && 'ml-4']}>
                <a
                  href={`#${heading.slug}`}
                  class="text-sm text-muted hover:text-forest transition-colors"
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <!-- Post body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Back to blog -->
      <div class="mt-16 pt-8 border-t border-border">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-forest hover:text-forest-light font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to all posts
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
