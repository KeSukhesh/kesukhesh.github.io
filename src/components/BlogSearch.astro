---
interface SearchPost {
  id: string;
  title: string;
  description: string;
  tags: string[];
}

interface Props {
  posts: SearchPost[];
}

const { posts } = Astro.props;
---

<div class="mb-12" id="blog-search" data-posts={JSON.stringify(posts)}>
  <div class="relative">
    <svg
      class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted pointer-events-none"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="search"
      id="search-input"
      placeholder="Search posts..."
      autocomplete="off"
      class="w-full pl-12 pr-4 py-3 bg-paper border border-border rounded-xl text-ink placeholder:text-muted focus:outline-none focus:border-forest transition-colors font-mono text-sm"
    />
  </div>

  <div id="search-results" class="mt-4 hidden">
    <div id="search-results-list" class="space-y-4"></div>
    <p id="search-no-results" class="text-muted text-sm hidden">No posts found.</p>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  let fuse: Fuse<{ id: string; title: string; description: string; tags: string[] }> | null = null;

  function initSearch() {
    const container = document.getElementById('blog-search');
    if (!container) return;

    const posts = JSON.parse(container.dataset.posts || '[]');
    fuse = new Fuse(posts, {
      keys: [
        { name: 'title', weight: 0.4 },
        { name: 'description', weight: 0.3 },
        { name: 'tags', weight: 0.3 },
      ],
      threshold: 0.4,
      includeScore: true,
    });
  }

  function renderResults(results: Fuse.FuseResult<{ id: string; title: string; description: string }>[] | null) {
    const container = document.getElementById('search-results');
    const list = document.getElementById('search-results-list');
    const noResults = document.getElementById('search-no-results');
    if (!container || !list || !noResults) return;

    if (results === null) {
      container.classList.add('hidden');
      return;
    }

    container.classList.remove('hidden');

    if (results.length === 0) {
      list.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }

    noResults.classList.add('hidden');
    list.innerHTML = results
      .map(
        ({ item }) => `
        <a href="/blog/${item.id}" class="group block">
          <h3 class="font-medium group-hover:text-forest transition-colors">${item.title}</h3>
          <p class="text-sm text-muted">${item.description}</p>
        </a>
      `
      )
      .join('');
  }

  function setupSearch() {
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    if (!input) return;

    input.addEventListener('focus', () => {
      if (!fuse) initSearch();
    });

    input.addEventListener('input', () => {
      if (!fuse) initSearch();
      const query = input.value.trim();
      if (!query) {
        renderResults(null);
        return;
      }
      renderResults(fuse!.search(query));
    });
  }

  setupSearch();
  document.addEventListener('astro:after-swap', setupSearch);
</script>
